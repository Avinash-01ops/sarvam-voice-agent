# Sarvam Voice Agent - Environment Configuration
# ================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control!

# Required: Sarvam API Key
# Get your key from: https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional: Sarvam API Base URL (usually don't need to change)
# SARVAM_API_BASE_URL=https://api.sarvam.ai

# Optional: Speech-to-Text Configuration
# STT_MODEL=saaras:v3
# STT_LANGUAGE=unknown
# STT_MODE=transcribe

# Optional: Text-to-Speech Configuration
# TTS_MODEL=bulbul:v3
# TTS_LANGUAGE=en-IN
# TTS_SPEAKER=shubh
# TTS_SAMPLE_RATE=24000

# Optional: LLM Configuration
# LLM_MODEL=sarvam-30b
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=1000
# LLM_TOP_P=1.0

# Optional: Audio Recording Configuration
# RECORD_SAMPLE_RATE=16000
# RECORD_CHANNELS=1
# RECORD_SECONDS=10
# RECORD_SILENCE_THRESHOLD=500
# RECORD_SILENCE_DURATION=2.0

# Optional: File Paths
# INPUT_AUDIO_PATH=input.wav
# OUTPUT_AUDIO_PATH=response.wav

# Optional: Retry Configuration
# MAX_RETRIES=3
# RETRY_DELAY_SECONDS=2.0

# Optional: Conversation Configuration
# SYSTEM_PROMPT=You are a helpful, friendly voice assistant. Keep your responses concise and conversational.
# MAX_CONVERSATION_HISTORY=20
